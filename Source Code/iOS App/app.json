{
  "name": "RayziIOS",
  "displayName": "Rayzi Ultimate",
  "version": "1.0.0",
  "description": "Rayzi Ultimate - Gaming Platform",
  "expo": {
    "name": "Rayzi Ultimate",
    "slug": "rayzi-ultimate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#e60a57"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rayzi.ultimate",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow camera access for profile pictures",
        "NSPhotoLibraryUsageDescription": "Allow photo library access for profile pictures",
        "NSMicrophoneUsageDescription": "Allow microphone access for voice chat",
        "UIAppSupportsHDR": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "UIViewControllerBasedStatusBarAppearance": false
      },
      "config": {
        "googleSignIn": {
          "reservedClientId": "YOUR_RESERVED_CLIENT_ID"
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#e60a57"
      },
      "package": "com.rayzi.ultimate",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ]
    ]
  }
}
