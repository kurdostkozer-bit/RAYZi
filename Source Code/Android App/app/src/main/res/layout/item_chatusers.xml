<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:custom="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_3sdp"
        custom:cardBackgroundColor="#39273A"
        custom:cardCornerRadius="@dimen/_10sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#39273A"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp">

                <com.example.rayzi.utils.UserProfileImageView
                    android:id="@+id/imguser"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_marginStart="5dp" />

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="15dp"
                    android:layout_toStartOf="@id/tvtime"
                    android:layout_toEndOf="@id/imguser"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/lytname"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvusername"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/abold"
                            android:text="Johnny Rios"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_12sdp" />

                        <TextView
                            android:id="@+id/tvcountry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_5dp"
                            android:backgroundTint="@color/pink"
                            android:fontFamily="@font/alight"
                            android:paddingHorizontal="5dp"
                            android:paddingVertical="2dp"
                            android:text="COUNTRY"
                            android:textColor="@color/white"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvlastchet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/lytname"
                        android:layout_gravity="bottom"
                        android:layout_marginTop="5dp"
                        android:singleLine="true"
                        android:fontFamily="@font/alight"
                        android:text="Hay, how was going?"
                        android:textColor="#BBBBBB" />

                </RelativeLayout>

                <TextView
                    android:id="@+id/tvtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="5dp"
                    android:fontFamily="@font/alight"
                    android:text="12:33 PM"
                    android:textColor="#BBBBBB"
                    android:textSize="10sp" />

                <LinearLayout
                    android:id="@+id/layCount"
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/count_bg"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="6dp"
                    android:layout_marginTop="3dp"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_below="@id/tvtime">

                <TextView
                    android:id="@+id/tvCount"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/abold"
                    android:text="30"
                    android:textColor="@color/white"
                    android:textSize="10sp" />

                </LinearLayout>

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height=".3dp"
                android:layout_marginTop="10dp"
                android:background="@color/graylight"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</layout>