<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg"
        tools:context=".user.wallet.coinseller.SellerRechargeFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/cardTemp"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="15dp"
                android:elevation="5dp"
                app:cardCornerRadius="14dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:background="@drawable/bg_recharge_text">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="20dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/abold"
                            android:text="@string/diamond_balance"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_14sdp" />

                        <TextView
                            android:id="@+id/tvMyCoins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:fontFamily="@font/abold"
                            android:text="0"
                            android:textColor="@color/yellow"
                            android:textSize="@dimen/_24sdp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/daimondstar"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="10dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/diamond" />

                </RelativeLayout>

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="30dp"
                android:gravity="end"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp">

                    <EditText
                        android:id="@+id/etUserId"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/stroke_bg_10dp"
                        android:fontFamily="@font/amidum"
                        android:hint="@string/enter_user_id"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:paddingHorizontal="5dp"
                        android:singleLine="true"
                        android:text=""
                        android:textAlignment="viewStart"
                        android:textColor="@color/white"
                        android:textColorHint="@color/lightgray" />

                    <ImageView
                        android:id="@+id/ivFind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:src="@drawable/ic_done" />

                </RelativeLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="5dp"
                    android:fontFamily="@font/amidum"
                    android:visibility="gone"
                    android:text=""
                    android:layout_marginTop="2dp"
                    android:textColor="@color/white" />

                <EditText
                    android:id="@+id/etCoin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/stroke_bg_10dp"
                    android:fontFamily="@font/amidum"
                    android:hint="@string/enter_diamonds"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:paddingHorizontal="5dp"
                    android:singleLine="true"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/lightgray" />

                <EditText
                    android:id="@+id/etBaht"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/stroke_bg_10dp"
                    android:fontFamily="@font/amidum"

                    android:hint="@string/note"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="5dp"
                    android:singleLine="true"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/lightgray" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnTopup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="50dp"
                android:background="@drawable/bg_gradient_round"
                android:backgroundTint="#39273A"
                android:fontFamily="@font/abold"
                android:gravity="center"
                android:paddingHorizontal="70dp"
                android:paddingVertical="10dp"
                android:text="@string/top_up"
                android:textColor="@color/white"
                android:textSize="22dp" />

        </LinearLayout>

    </RelativeLayout>

</layout>