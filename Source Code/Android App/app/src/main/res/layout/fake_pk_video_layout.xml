<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:id="@+id/pk_host_pk_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <RelativeLayout
                android:id="@+id/pk_host_video_layout_container"
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <LinearLayout
                    android:id="@+id/pk_host_video_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="5dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="1dp"
                            app:cardBackgroundColor="@color/transparent">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <com.google.android.exoplayer2.ui.PlayerView
                                        android:id="@+id/playerviewLeft"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_centerInParent="true"
                                        app:buffered_color="@color/pink"
                                        app:resize_mode="fill"
                                        app:show_buffering="never"
                                        app:use_controller="false"
                                        tools:layout_editor_absoluteX="-16dp"
                                        tools:layout_editor_absoluteY="0dp" />

                                </androidx.constraintlayout.widget.ConstraintLayout>


                                <ImageView
                                    android:id="@+id/imgResult1"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter_left"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter2_left"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                            </RelativeLayout>

                        </androidx.cardview.widget.CardView>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="5dp"
                            android:layout_marginStart="1dp"
                            android:layout_marginEnd="3dp"
                            app:cardBackgroundColor="@color/transparent">

                            <RelativeLayout
                                android:id="@+id/pk_host_video_layout_right_container"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1">

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <com.google.android.exoplayer2.ui.PlayerView
                                        android:id="@+id/playerviewRight"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_centerInParent="true"
                                        app:buffered_color="@color/pink"
                                        app:resize_mode="fill"
                                        app:show_buffering="never"
                                        app:use_controller="false" />


                                </androidx.constraintlayout.widget.ConstraintLayout>

                                <ImageView
                                    android:id="@+id/imgFilter_right"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter2_right"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgResult2"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/pk_video_layout_other_host_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentBottom="true"
                                    android:layout_marginStart="24dp"
                                    android:layout_marginBottom="24dp"
                                    android:textColor="@android:color/white"
                                    android:textSize="14dp" />


                            </RelativeLayout>


                        </androidx.cardview.widget.CardView>

                    </FrameLayout>

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/userLayBorder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="5dp"
                        android:layout_marginStart="3dp"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/shape_golden_border" />


                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="5dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter" />


                </LinearLayout>

            </RelativeLayout>


            <LinearLayout
                android:id="@+id/pk_host_pk_progress_layout"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_below="@id/pk_host_video_layout_container"
                android:background="@drawable/pk_progress_round_scalable_white_bg"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/pk_progress_left_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#6190F0"
                    android:orientation="horizontal" />


                <LinearLayout
                    android:layout_width="30dp"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#6190F0"
                        android:orientation="horizontal" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#BA1D71"
                        android:orientation="horizontal" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pk_progress_right_text"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="#BA1D71"
                    android:orientation="horizontal" />

            </LinearLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_below="@id/pk_host_video_layout_container"
                android:layout_marginTop="-10dp"
                android:orientation="horizontal"
                android:padding="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="25dp">

                    <LinearLayout
                        android:id="@+id/pk_progress_left_text1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal" />

                    <ImageView
                        android:id="@+id/sparkle"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_marginTop="5dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:id="@+id/pk_progress_right_text1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="horizontal" />

                </LinearLayout>

                <TextView
                    android:id="@+id/localHostRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginLeft="4dp"
                    android:layout_marginTop="@dimen/_7sdp"
                    android:layout_marginBottom="2dp"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16dp"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/remoteHostRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/_7sdp"
                    android:layout_marginRight="4dp"
                    android:layout_marginBottom="2dp"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16dp"
                    android:visibility="visible" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_below="@+id/pk_host_pk_progress_layout"
                android:layout_centerHorizontal="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_star_pk" />

                <ImageView
                    android:id="@+id/left_host"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="15dp"
                    android:layout_toStartOf="@+id/vs"
                    android:src="@drawable/girl" />

                <ImageView
                    android:id="@+id/vs"
                    android:layout_width="50dp"
                    android:layout_height="60dp"
                    android:layout_centerInParent="true"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/icon_pk_vs" />

                <ImageView
                    android:id="@+id/right_host"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_toEndOf="@+id/vs"
                    android:src="@drawable/girl" />


            </RelativeLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <RelativeLayout
                        android:id="@+id/lyt_pk_right"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:adjustViewBounds="true"
                            android:src="@drawable/pk_side_blue" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_marginHorizontal="12dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="horizontal">


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginHorizontal="10dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/hostNameRight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/abold"
                                    android:singleLine="true"
                                    android:text="Host Name"
                                    android:textColor="@color/pink"
                                    android:textSize="14dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/amidum"
                                    android:singleLine="true"
                                    android:text="Opponent"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/lytHostImageRight"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop" />

                        </LinearLayout>

                    </RelativeLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:id="@+id/lyt_pk_left"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:adjustViewBounds="true"
                            android:src="@drawable/pk_side_pink" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_marginHorizontal="12dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/lytHostImageLeft"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:adjustViewBounds="true"
                                android:scaleType="centerCrop" />


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginHorizontal="10dp"
                                android:orientation="vertical">


                                <TextView
                                    android:id="@+id/hostNameLeft"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/abold"
                                    android:singleLine="true"
                                    android:text="Host Name"
                                    android:textColor="#1046B5"
                                    android:textSize="14dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/amidum"
                                    android:singleLine="true"
                                    android:text="Me"
                                    android:textColor="@color/white"
                                    android:textSize="14dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </RelativeLayout>


                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />


                </LinearLayout>
            </LinearLayout>

            <!--            <com.airbnb.lottie.LottieAnimationView-->
            <!--                android:id="@+id/pkAnim"-->
            <!--                android:layout_width="200dp"-->
            <!--                android:layout_height="200dp"-->
            <!--                android:layout_centerInParent="true"-->
            <!--                android:visibility="visible"-->
            <!--                app:lottie_loop="true"-->
            <!--                app:lottie_rawRes="@raw/pk_cresh" />-->

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/pk_host_remaining_time_layout"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:background="@drawable/round_scalable_gray_bg"
            android:orientation="horizontal"
            android:padding="5dp">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:text="CountDown :"
                android:textColor="@color/gray_icon"
                android:textSize="10sp"
                android:visibility="gone" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="4dp"
                android:gravity="center_vertical"
                android:src="@drawable/icon_pk_countdown" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/pk_host_remaining_time_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:textAlignment="gravity"
                android:textColor="@color/white"
                android:textSize="12dp" />

        </LinearLayout>


        <ImageView
            android:id="@+id/filter"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_centerInParent="true" />


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/vs_img"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="230dp"
                android:src="@drawable/vs_zoom" />

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="310dp">

            <ImageView
                android:id="@+id/giftImg"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/girl"
                android:visibility="gone" />


        </RelativeLayout>


    </RelativeLayout>
</layout>