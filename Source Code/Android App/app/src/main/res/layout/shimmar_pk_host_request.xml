<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp">


            <ImageView
                android:id="@+id/imageUser"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/shape_white_round"
                android:backgroundTint="@color/shimmercolor" />

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:layout_toEndOf="@id/imageUser"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/lytname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="60dp"
                        android:layout_height="15dp"
                        android:background="@drawable/bg_10dp"
                        android:backgroundTint="@color/shimmercolor"
                        android:fontFamily="@font/abold" />


                    <TextView
                        android:id="@+id/tvCountry"
                        android:layout_width="100dp"
                        android:layout_height="15dp"
                        android:layout_below="@id/lytname"
                        android:layout_gravity="bottom"
                        android:layout_marginTop="5dp"
                        android:background="@drawable/bg_10dp"
                        android:backgroundTint="@color/shimmercolor" />

                </LinearLayout>

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/lytAdd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/bg_round_pink"
                android:backgroundTint="@color/shimmercolor"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:paddingVertical="3dp"
                    android:textColor="@color/shimmercolor"
                    android:textSize="16dp" />


            </LinearLayout>

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height=".3dp"
            android:layout_marginTop="10dp"
            android:background="@color/graylight"
            android:visibility="gone" />

    </LinearLayout>
</layout>