<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="330dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:elevation="5dp"
            app:cardBackgroundColor="@color/black_back"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/black_back"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#191922"
                    android:fontFamily="@font/abold"
                    android:gravity="center"
                    android:paddingVertical="@dimen/_14sdp"
                    android:text="@string/r_coin_convert"
                    android:textColor="@color/pink"
                    android:textSize="@dimen/_15sdp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/_18sdp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/_38sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:layout_marginEnd="@dimen/_5sdp"
                        android:src="@drawable/rcoin" />

                    <ImageView
                        android:layout_width="@dimen/_38sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:padding="@dimen/_5sdp"
                        android:src="@drawable/convert" />

                    <ImageView
                        android:layout_width="@dimen/_38sdp"
                        android:layout_height="@dimen/_38sdp"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:src="@drawable/diamond" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@color/black_back"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="30dp">

                    <TextView
                        android:id="@+id/tvText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:fontFamily="@font/amidum"
                        android:gravity="center"
                        android:text="@string/how_much_coins_convert_into_diamonds"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/etRcoin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="40dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_10dp_stockwhite"
                        android:backgroundTint="#191922"
                        android:fontFamily="@font/amidum"
                        android:gravity="center"
                        android:hint="@string/enter_coins"
                        android:inputType="number"
                        android:lineSpacingExtra="5dp"
                        android:maxLength="8"
                        android:paddingVertical="@dimen/_12sdp"
                        android:singleLine="true"
                        android:textColor="@color/offwhite"
                        android:textColorHint="@color/extra_light_grey"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvDiamondsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:layout_marginEnd="40dp"
                        android:fontFamily="@font/amidum"
                        android:text=""
                        android:textColor="@color/yellow"
                        android:textSize="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height=".3dp"
                        android:layout_marginTop="20dp"
                        android:background="@color/blacklight" />

                    <TextView
                        android:id="@+id/btncountinue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/pink"
                        android:fontFamily="@font/abold"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="15dp"
                        android:text="@string/convert_to_diamonds"
                        android:textColor="@color/pink"
                        android:textSize="16dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height=".3dp"
                        android:background="@color/blacklight" />

                    <TextView
                        android:id="@+id/btnCancel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:backgroundTint="@color/pink"
                        android:fontFamily="@font/abold"
                        android:gravity="center"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="15dp"
                        android:text="@string/cancel"
                        android:textColor="@color/white"
                        android:textSize="16dp" />
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
    </LinearLayout>
</layout>