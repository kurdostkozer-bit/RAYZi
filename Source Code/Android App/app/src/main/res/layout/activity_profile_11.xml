<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.example.rayzi.activity.ProfileActivity.ProfileViewModel" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg"
        tools:context=".user.ProfileFragment">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/layMain"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <RelativeLayout
                    android:id="@+id/layDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="@{viewModel.isLoading?View.GONE : View.VISIBLE}">

                    <RelativeLayout
                        android:id="@+id/mainRel"
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <ImageView
                            android:id="@+id/imgUser1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/bg_cover_image" />

                        <ImageView
                            android:id="@+id/ivBack"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginTop="@dimen/_35sdp"
                            android:src="@drawable/ic_back"
                            android:padding="5dp"
                            android:layout_marginStart="15dp"
                            app:tint="@color/white" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_marginTop="@dimen/_35sdp"
                            android:layout_marginEnd="@dimen/_15sdp">


                            <ImageView
                                android:id="@+id/btnEditProfile"
                                android:layout_width="@dimen/_25sdp"
                                android:layout_height="@dimen/_25sdp"
                                android:layout_marginStart="13dp"
                                android:src="@drawable/ic_edit_profile" />

                            <ImageView
                                android:id="@+id/btnSetting"
                                android:layout_width="@dimen/_25sdp"
                                android:layout_height="@dimen/_25sdp"
                                android:layout_marginStart="@dimen/_10sdp"
                                android:src="@drawable/ic_setting" />

                        </LinearLayout>

                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="140dp">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/layImg"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:layout_gravity="center"
                                app:cardCornerRadius="20dp">

                                <ImageView
                                    android:id="@+id/imgUser2"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/profileimage_stroke" />

                            </androidx.cardview.widget.CardView>

                            <com.example.rayzi.utils.UserProfileImageView
                                android:id="@+id/imgUser"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:src="@drawable/default_user_image"
                                android:visibility="gone" />

                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="20dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/abold"
                                android:singleLine="true"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_15sdp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvUserId"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/amidum"
                                    android:gravity="center"
                                    android:text="ID: 998877"
                                    android:textColor="#A4A4A4"
                                    android:textSize="@dimen/_10sdp" />

                                <ImageView
                                    android:id="@+id/copy"
                                    android:layout_width="13dp"
                                    android:layout_height="13dp"
                                    android:layout_gravity="center"
                                    android:layout_marginStart="5dp"
                                    android:layout_marginRight="5dp"
                                    android:src="@drawable/ion_copy"
                                    app:tint="@color/graylight" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvLevel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_5dp_radius"
                                    android:backgroundTint="#CD406A"
                                    android:paddingHorizontal="5dp"
                                    android:paddingVertical="2dp"
                                    android:textSize="12dp"
                                    android:text="Level 1"
                                    android:textColor="@color/white" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:background="@drawable/bg_5dp_radius"
                                    android:backgroundTint="#8D2BE4"
                                    android:orientation="horizontal">

                                    <ImageView
                                        android:id="@+id/imgGender"
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:layout_marginStart="3dp"
                                        android:padding="2dp"
                                        android:src="@drawable/female"
                                        app:tint="@color/white" />

                                    <TextView
                                        android:id="@+id/tvAge"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="5dp"
                                        android:paddingVertical="2dp"
                                        android:textSize="12dp"
                                        android:text="0"
                                        android:textColor="@color/white" />

                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/layType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:background="@drawable/bg_5dp_radius"
                                    android:backgroundTint="#ED6B0C"
                                    android:orientation="horizontal"
                                    android:visibility="gone">

                                    <ImageView
                                        android:id="@+id/ivType"
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:layout_marginStart="3dp"
                                        android:padding="2dp"
                                        android:src="@drawable/ic_agency"
                                        app:tint="@color/white" />

                                    <TextView
                                        android:id="@+id/tvType"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="3dp"
                                        android:paddingVertical="2.5dp"
                                        android:text="Agency"
                                        android:textSize="12dp"
                                        android:textColor="@color/white" />

                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/layHostType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:background="@drawable/bg_5dp_radius"
                                    android:backgroundTint="#4CAF50"
                                    android:orientation="horizontal"
                                    android:visibility="gone">

                                    <ImageView
                                        android:id="@+id/ivHostType"
                                        android:layout_width="17dp"
                                        android:layout_height="17dp"
                                        android:layout_gravity="center"
                                        android:layout_marginStart="3dp"
                                        android:padding="2dp"
                                        android:src="@drawable/ic_agency"
                                        app:tint="@color/white" />

                                    <TextView
                                        android:id="@+id/tvHostType"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:paddingHorizontal="5dp"
                                        android:paddingVertical="2.5dp"
                                        android:text="Creator"
                                        android:textSize="12dp"
                                        android:textColor="@color/white" />

                                </LinearLayout>

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layVIPType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_5dp_radius"
                                android:backgroundTint="#FEAD2A"
                                android:layout_marginTop="5dp"
                                android:orientation="horizontal"
                                android:visibility="visible">

                                <ImageView
                                    android:id="@+id/ivVIPType"
                                    android:layout_width="17dp"
                                    android:layout_height="17dp"
                                    android:layout_gravity="center"
                                    android:layout_marginStart="3dp"
                                    android:padding="2dp"
                                    android:src="@drawable/crown"
                                    app:tint="@color/white" />

                                <TextView
                                    android:id="@+id/tvVIPType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingHorizontal="5dp"
                                    android:paddingVertical="2dp"
                                    android:textSize="12dp"
                                    android:text="VIP"
                                    android:textColor="@color/white" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/mainRel"
                        android:layout_marginTop="@dimen/_35sdp"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:visibility="@{viewModel.isLoading?View.GONE : View.VISIBLE}"
                                    tools:visibility="visible">

                                </LinearLayout>

                            </RelativeLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="15dp"
                                android:orientation="vertical">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:weightSum="3">

                                    <LinearLayout
                                        android:id="@+id/lytFollowing"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/amidum"
                                            android:text="@string/following"
                                            android:textColor="#B3FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                        <TextView
                                            android:id="@+id/tvFollowing"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="0"
                                            android:textColor="#FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytFollowrs"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:gravity="center"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/amidum"
                                            android:text="@string/fans"
                                            android:textColor="#B3FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                        <TextView
                                            android:id="@+id/tvFollowrs"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="0"
                                            android:textColor="#FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytBlock"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:gravity="center"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/amidum"
                                            android:text="Blocked User :"
                                            android:textColor="#B3FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                        <TextView
                                            android:id="@+id/tvBlock"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="0"
                                            android:textColor="#FFFFFF"
                                            android:textSize="@dimen/_12sdp" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/layWallet"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_60sdp"
                                    android:layout_marginTop="@dimen/_5sdp"
                                    android:background="@drawable/wallet_bg"
                                    android:gravity="center"
                                    android:padding="@dimen/_10sdp">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/amidum"
                                            android:text="@string/my_diamonds"
                                            android:textColor="@color/white_50"
                                            android:textSize="@dimen/_10sdp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp">

                                            <ImageView
                                                android:layout_width="@dimen/_23sdp"
                                                android:layout_height="@dimen/_23sdp"
                                                android:src="@drawable/diamond" />

                                            <TextView
                                                android:id="@+id/tvCoin"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_gravity="center"
                                                android:layout_marginStart="@dimen/_10sdp"
                                                android:fontFamily="@font/abold"
                                                android:text=""
                                                android:textColor="#F0C353"
                                                android:textSize="@dimen/_18sdp" />

                                        </LinearLayout>

                                    </LinearLayout>

                                    <ImageView
                                        android:layout_width="@dimen/_15sdp"
                                        android:layout_height="@dimen/_15sdp"
                                        android:src="@drawable/ic_next_1" />

                                </LinearLayout>

                                <androidx.recyclerview.widget.RecyclerView
                                    android:id="@+id/rvOptions"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                                    app:spanCount="4"
                                    tools:listitem="@layout/item_rvprofile" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"
                                    android:layout_marginTop="@dimen/_20sdp"
                                    android:gravity="center">

                                    <LinearLayout
                                        android:id="@+id/layAgency"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:id="@+id/ivAgency"
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_agency_center" />

                                        <TextView
                                            android:id="@+id/tvAgency"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Demo Agency"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/layHost"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:id="@+id/ivHost"
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_host_center" />

                                        <TextView
                                            android:id="@+id/tvHost"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Host Center"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/layhostrequest"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_host_request" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Host Request"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytCoinSeller"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_coin_seller" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Coin Seller"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"
                                    android:layout_marginTop="@dimen/_20sdp"
                                    android:gravity="center">

                                    <LinearLayout
                                        android:id="@+id/lytMyPost"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_my_post1" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="My posts"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytMyVideos"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_my_relites" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="My relites"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytStore"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_store" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Store"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/lytFreeDimonds"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_free_coin" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Free Coins"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:visibility="gone"
                                    android:layout_marginTop="@dimen/_25sdp"
                                    android:gravity="center">

                                    <LinearLayout
                                        android:id="@+id/lytVIP"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_become_vip" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="Become VIP"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/layUserLevel"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_user_level" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="User Level"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:visibility="invisible">

                                        <ImageView
                                            android:layout_width="@dimen/_40sdp"
                                            android:layout_height="@dimen/_40sdp"
                                            android:src="@drawable/ic_user_level" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:fontFamily="@font/amidum"
                                            android:text="User Level"
                                            android:textColor="@color/white"
                                            android:textSize="@dimen/_9sdp" />

