<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.example.rayzi.pk.viewmodel.PKLiveViewModel" />

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".pk.HostPKLiveActivity">

        <RelativeLayout
            android:id="@+id/singleLiveLay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:context=".liveStreamming.LiveActivity">

            <com.example.rayzi.agora.ui.VideoGridContainer
                android:id="@+id/live_video_grid_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <ImageView
                android:id="@+id/hostProfileBig"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bulr_bg" />

            <ImageView
                android:id="@+id/imgFilter"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha=".3"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/imgFilter2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha=".3"
                android:scaleType="centerCrop" />

            <com.example.rayzi.pk.views.PkLayout
                android:id="@+id/pk_host_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/login_bg"
                android:paddingTop="120dp"
                android:visibility="visible">

            </com.example.rayzi.pk.views.PkLayout>

            <!--
                        <com.facebook.drawee.view.SimpleDraweeView
                            android:id="@+id/imgSticker"
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:layout_centerInParent="true"
                            android:adjustViewBounds="true"
                            app:actualImageScaleType="fitCenter" />
            -->


            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/lytGift"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:visibility="invisible">

                        <ImageView
                            android:id="@+id/imgGift"
                            android:layout_width="200dp"
                            android:layout_height="200dp"
                            android:src="@drawable/ic_gift" />

                        <ImageView
                            android:id="@+id/imgGiftCount"
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            android:layout_marginStart="-50dp"
                            android:src="@drawable/x10" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvGiftUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/abold"
                        android:text=""
                        android:textColor="@color/pink"
                        android:textSize="16dp"
                        android:visibility="visible" />

                </LinearLayout>


                <com.opensource.svgaplayer.SVGAImageView
                    android:id="@+id/svgaImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:visibility="visible"
                    app:autoPlay="false" />

            </RelativeLayout>



            <LinearLayout
                android:id="@+id/lytTop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/lytHost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10sp"
                        android:background="@drawable/round_white_trans"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_gravity="center"
                            android:layout_marginVertical="5dp"
                            android:layout_marginStart="5dp"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="25dp">

                            <com.example.rayzi.utils.UserProfileImageView
                                android:id="@+id/imgProfile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:background="@drawable/girl"
                                android:scaleType="centerCrop" />

                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginVertical="3dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/abold"
                                android:text="monkey mino"
                                android:textColor="@color/white"
                                android:textSize="@dimen/_11sdp" />

                            <TextView
                                android:id="@+id/tvUniqueId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:fontFamily="@font/amidum"
                                android:text="ID : 564321"
                                android:textColor="@color/gray"
                                android:textSize="@dimen/_8sdp" />

                        </LinearLayout>

                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvViewUsers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:layout_gravity="center"
                            android:adapter="@{viewModel.liveViewUserAdapter}"
                            android:fadingEdge="horizontal"
                            android:fadingEdgeLength="10dp"
                            android:orientation="horizontal"
                            android:requiresFadingEdge="horizontal"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            tools:listitem="@layout/item_view_users" />

                        <TextView
                            android:id="@+id/tvNoOneJoined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_5dp"
                            android:backgroundTint="@color/pink"
                            android:fontFamily="@font/abold"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="5dp"
                            android:singleLine="true"
                            android:text="No one Joined"
                            android:textColor="@color/white" />

                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/lytviewcount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:background="@drawable/bg_gradient_round_black"
                        android:backgroundTint="@color/black_alpha_20"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="5dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:padding="2dp"
                            android:src="@drawable/ic_eye"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvViewUserCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:fontFamily="@font/amidum"
                            android:text="0"
                            android:textColor="@color/white" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgblock"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:layout_marginLeft="5dp"
                        android:padding="3dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_block_user" />

                    <ImageView
                        android:id="@+id/imgshare"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="5dp"
                        android:layout_marginLeft="5dp"
                        android:padding="3dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/a_share" />

                    <ImageView
                        android:id="@+id/btnClose"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="15dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_gradient_round"
                        android:backgroundTint="@color/black_alpha_20"
                        android:padding="1dp"
                        android:src="@drawable/a_close"
                        app:tint="@color/white" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_gradient_round_black_transperent_oneside"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:padding="4dp"
                                android:src="@drawable/money" />

                            <TextView
                                android:id="@+id/tvRcoin"
                                android:layout_width="50dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:minWidth="50dp"
                                android:text="0"
                                android:textColor="@color/yellow"
                                android:textSize="14dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rCoinLyt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/round_white_trans"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="25dp"
                                android:layout_height="25dp"
                                android:padding="4dp"
                                android:src="@drawable/rcoin" />

                            <TextView
                                android:id="@+id/tvRcoins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:minWidth="50dp"
                                android:text="31"
                                android:textColor="@color/yellow"
                                android:textSize="14dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lytPrivacy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/transparent_gradient_private"
                        android:gravity="center"
                        android:visibility="gone"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:paddingVertical="5dp">

                        <ImageView

                            android:id="@+id/imgPrivacyk"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:padding="3dp"
                            android:src="@drawable/unlock"
                            app:tint="@color/white" />

                        <TextView
                            android:id="@+id/tvPrivacy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="5dp"
                            android:fontFamily="@font/amidum"
                            android:includeFontPadding="false"
                            android:text="Public"
                            android:textColor="@color/white"
                            android:textSize="14dp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/btnRepot"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_gravity="end"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:onClick="onClickReport"
                        android:src="@drawable/ic_baseline_info_24"
                        android:tooltipText="Report This User"
                        android:visibility="visible" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/tvtimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/lytTop"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/round_white_trans"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:shadowColor="@color/white"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="2"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/lytFilterFunctions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@+id/lytTop"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="10dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:onClick="onClickGifIcon"
                    android:src="@drawable/ic_filter" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:onClick="onClickFilter"
                    android:src="@drawable/ic_effect" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:onClick="onClickStickerIcon"
                    android:src="@drawable/ic_stickers"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="#9013FE"
                    android:onClick="onClickEmojiIcon"
                    android:src="@drawable/ic_emoji_hist"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_switch_camera"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:onClick="onSwitchCameraClicked"
                    android:src="@drawable/flip" />

                <ImageView
                    android:id="@+id/btn_mute"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:onClick="onLocalAudioMuteClicked"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/unmute" />

                <ImageView
                    android:id="@+id/btnHostList"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="10dp"
                    android:src="@drawable/pk_icon"
                    android:visibility="visible" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytSvgagift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/giftusername_bg"
                android:layout_below="@id/tvtimer"
                android:paddingHorizontal="15dp"
                android:paddingVertical="5dp"
                android:layout_marginTop="50dp"
                android:layout_marginStart="10dp"
                android:visibility="gone"
                android:layout_marginEnd="5dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvSvgaGiftUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/abold"
                    android:text="jems bond send a gift"
                    android:textColor="@color/white"
                    android:textSize="14dp"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/imgSvgaGiftCount"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="7dp"
                    android:src="@drawable/x10" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginVertical="5dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/comment_bg"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="300dp"
                    android:layout_height="200dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvComments"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_alignParentTop="true"
                        android:layout_marginStart="10dp"
                        android:adapter="@{viewModel.pkLiveStramCommentAdapter}"
                        android:orientation="vertical"
                        android:visibility="visible"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        app:reverseLayout="true"
                        tools:listitem="@layout/item_livestream_comment_1" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/lytBottomBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fitsSystemWindows="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toLeftOf="@+id/lytbuttons"
                        android:background="@drawable/bg_etblack_a"
                        android:orientation="horizontal">


                        <EditText
                            android:id="@+id/etComment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="@dimen/_30sdp"
                            android:background="@android:color/transparent"
                            android:fontFamily="@font/alight"
                            android:hint="Add a Comment..."
                            android:paddingVertical="10dp"
                            android:singleLine="true"
                            android:textColor="@color/white"
                            android:textColorHint="@color/white"
                            android:textSize="14sp"
                            android:visibility="visible" />

                        <ImageView
                            android:id="@+id/btnsend"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="5dp"
                            android:onClick="onClickSendComment"
                            android:padding="8dp"
                            android:src="@drawable/a_send"
                            android:visibility="visible" />

                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/lytbuttons"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentRight="true"
                        android:layout_gravity="end"
                        android:gravity="end"
                        android:orientation="horizontal"
                        android:paddingEnd="10sp"
                        android:paddingRight="10sp">

                        <ImageView
                            android:id="@+id/imggift2"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginLeft="5dp"
                            android:padding="1dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/a_gift"
                            android:visibility="visible" />

                        <ImageView
                            android:id="@+id/imgGame"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginLeft="5dp"
                            android:padding="3dp"
                            android:scaleType="centerCrop"
                            android:src="@drawable/a_game_ic" />

                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

            <RelativeLayout
                android:id="@+id/lytFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:background="@drawable/bg_sheettransperent"
                android:backgroundTint="@color/grayinsta"
                android:paddingTop="5dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imgfilterclose"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="10dp"
                    android:onClick="@{()->viewModel.onClickSheetClose()}"
                    android:padding="7dp"
                    android:src="@drawable/ic_close"
                    app:tint="@color/white" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFilters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_filters" />

            </RelativeLayout>

            <include layout="@layout/layout_no_internet" />
        </RelativeLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/mining"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/loder2" />

        <RelativeLayout
            android:id="@+id/layEntry"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <com.opensource.svgaplayer.SVGAImageView
                android:id="@+id/svgImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_alignParentBottom="true"
                app:autoPlay="true" />

            <RelativeLayout
                android:id="@+id/nameLyt"
                android:layout_width="@dimen/_155sdp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="@dimen/_50sdp">

                <LinearLayout
                    android:layout_width="@dimen/_130sdp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@drawable/entry_bg_name_stroke" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/entry_bg_name"
                        android:orientation="vertical"
                        android:paddingVertical="@dimen/_8sdp"
                        android:paddingStart="40dp">

                        <TextView
                            android:id="@+id/userName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="@font/amidum"
                            android:includeFontPadding="false"
                            android:text="Diamond Star"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_10sdp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/aregular"
                            android:includeFontPadding="false"
                            android:text="Comming!"
                            android:textColor="@color/white"
                            android:textSize="@dimen/_8sdp" />

                    </LinearLayout>

                    <View
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_1sdp"
                        android:background="@drawable/entry_bg_name_stroke" />

                </LinearLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true">

                    <ImageView
                        android:id="@+id/userImage"
                        android:layout_width="@dimen/_43sdp"
                        android:layout_height="@dimen/_43sdp"
                        android:layout_centerInParent="true"
                        android:background="@drawable/profile_entry_bg_blue"
                        android:padding="2dp" />

                    <ImageView
                        android:id="@+id/avatarFrameImage"
                        android:layout_width="@dimen/_55sdp"
                        android:layout_height="@dimen/_55sdp" />

                </RelativeLayout>

            </RelativeLayout>

        </RelativeLayout>

    </RelativeLayout>

</layout>