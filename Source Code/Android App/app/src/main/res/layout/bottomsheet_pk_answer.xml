<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_bottom_sheet_pink"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/abold"
                    android:paddingHorizontal="30dp"
                    android:text="@string/invitation_for_pk_battle"
                    android:textColor="#7654FF"
                    android:textSize="18dp" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="15dp"
                    android:src="@drawable/t2ticonforpk" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="10dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="15dp"
                        android:orientation="vertical"
                        android:paddingVertical="15dp">

                        <com.example.rayzi.utils.UserProfileImageView
                            android:id="@+id/requestingHostImage"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/malenewdefault" />


                    </LinearLayout>


                    <TextView
                        android:id="@+id/requestingHostName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/abold"
                        android:text="Host Name"
                        android:textColor="@color/white"
                        android:textSize="16dp" />

                    <TextView
                        android:id="@+id/timer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top"
                        android:layout_marginHorizontal="10dp"
                        android:background="@drawable/light_pink_round_corner"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="2.5dp"
                        android:text="00:00"
                        android:textColor="@color/redtext"
                        android:textSize="15dp" />


                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:fontFamily="@font/aregular"
                    android:gravity="center"
                    android:text="@string/join_pk_battle_to_gain_more_exposure_and_diamonds"
                    android:textColor="#999999"
                    android:textSize="15dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rejectPkRequest"
                        android:layout_width="170dp"
                        android:layout_height="60dp"
                        android:layout_marginHorizontal="10dp"
                        android:src="@drawable/pkrejectbtnicon" />

                    <ImageView
                        android:id="@+id/acceptPkRequest"
                        android:layout_width="170dp"
                        android:layout_height="60dp"
                        android:layout_marginHorizontal="10dp"
                        android:src="@drawable/pkacceptbtnicon" />
                </LinearLayout>
            </LinearLayout>


        </LinearLayout>
    </RelativeLayout>
</layout>