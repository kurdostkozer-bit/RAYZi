<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/black_back" />

                <ImageView
                    android:id="@+id/backImageBlur"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop" />

                <ImageView
                    android:id="@+id/reelBlur"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    android:src="#D1D1D1" />

            </RelativeLayout>

            <LinearLayout
                android:id="@+id/hostDetailsLyt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingBottom="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="bottom">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="15dp"
                        android:layout_weight="1"
                        android:gravity="start|center"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center"
                            android:gravity="center_vertical"
                            android:orientation="vertical">

                            <androidx.cardview.widget.CardView
                                android:id="@+id/hostName"
                                android:layout_width="200dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="5dp"
                                android:backgroundTint="@color/shimmercolor"
                                android:ellipsize="end"
                                android:fontFamily="@font/amidum"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:shadowColor="#000000"
                                android:shadowDx="0"
                                android:shadowDy="0"
                                android:shadowRadius="0.5"
                                android:text='Baku Mosambi'
                                android:textColor="@color/white"
                                android:textSize="20dp"
                                app:cardCornerRadius="10dp"
                                tools:text="\@your_samantha" />

                            <androidx.cardview.widget.CardView
                                android:id="@+id/hostBio"
                                android:layout_width="280dp"
                                android:layout_height="10dp"
                                android:layout_marginStart="5dp"
                                android:layout_marginTop="15dp"
                                android:backgroundTint="@color/shimmercolor"
                                android:ellipsize="end"
                                android:fontFamily="@font/amidum"
                                android:includeFontPadding="false"
                                android:maxLines="1"
                                android:shadowColor="#000000"
                                android:shadowDx="0"
                                android:shadowDy="0"
                                android:shadowRadius="0.5"
                                android:text='Baku Mosambi'
                                android:textColor="@color/white"
                                android:textSize="15dp"
                                app:cardCornerRadius="10dp"
                                tools:text="\@your_samantha" />

                        </LinearLayout>

                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnRepot"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="30dp"
            android:layout_marginEnd="15dp"
            android:backgroundTint="@color/shimmercolor"
            android:src="@drawable/baseline_more_vert_24"
            android:tooltipText="Report This Relite"
            android:visibility="visible"
            app:cardCornerRadius="20dp"
            app:tint="@color/white" />

    </RelativeLayout>

</layout>