<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="isHost"
            type="Boolean" />

        <import type="android.view.View" />
    </data>

    <RelativeLayout
        android:id="@+id/pk_host_pk_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_bg">

        <LinearLayout
            android:id="@+id/titleLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/pk_title_gradient">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/gluten_bold"
                android:gravity="center"
                android:includeFontPadding="false"
                android:paddingVertical="@dimen/_5sdp"
                android:text="@string/pk_battel"
                android:textColor="@color/white"
                android:textSize="@dimen/_18sdp" />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/mainLay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/titleLayout"
            android:layout_marginTop="10dp">


            <RelativeLayout
                android:id="@+id/pk_host_video_layout_container"
                android:layout_width="match_parent"
                android:layout_height="280dp">

                <LinearLayout
                    android:id="@+id/pk_host_video_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="5dp"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="1dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="10dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_weight="1">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Connecting..."
                                    android:textColor="@color/extra_light_grey"
                                    android:textSize="@dimen/_12sdp"
                                    android:layout_centerInParent="true"
                                    android:fontFamily="@font/amidum"
                                    android:includeFontPadding="false"/>

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <RelativeLayout
                                        android:id="@+id/pk_host_video_layout_left_container"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1">


                                    </RelativeLayout>

                                </androidx.constraintlayout.widget.ConstraintLayout>


                                <ImageView
                                    android:id="@+id/imgResult1"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter_left"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter2_left"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/userNameLeft"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentStart="true"
                                    android:fontFamily="@font/amidum"
                                    android:includeFontPadding="false"
                                    android:shadowColor="@color/black_back"
                                    android:shadowDx="2"
                                    android:layout_margin="@dimen/_5sdp"
                                    android:shadowDy="2"
                                    android:shadowRadius="2"
                                    android:text="ID: 143754"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_12sdp"
                                    android:visibility="@{isHost?View.GONE:View.VISIBLE}" />


                            </RelativeLayout>

                        </androidx.cardview.widget.CardView>

                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginVertical="5dp"
                            android:layout_marginStart="1dp"
                            android:layout_marginEnd="3dp"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="10dp">

                            <RelativeLayout
                                android:id="@+id/pk_host_video_layout_right_container"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_weight="1">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Connecting..."
                                    android:textColor="@color/extra_light_grey"
                                    android:textSize="@dimen/_12sdp"
                                    android:layout_centerInParent="true"
                                    android:fontFamily="@font/amidum"
                                    android:includeFontPadding="false"/>

                                <androidx.constraintlayout.widget.ConstraintLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent">

                                    <FrameLayout
                                        android:id="@+id/pk_host_video_layout_right"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        tools:layout_editor_absoluteX="0dp"
                                        tools:layout_editor_absoluteY="0dp" />

                                    <!--                                    <TextView-->
                                    <!--                                        android:id="@+id/rightText"-->
                                    <!--                                        android:layout_width="wrap_content"-->
                                    <!--                                        android:layout_height="wrap_content"-->
                                    <!--                                        android:gravity="center"-->
                                    <!--                                        android:text="Waitting for response...."-->
                                    <!--                                        android:textColor="@color/white"-->
                                    <!--                                        app:layout_constraintStart_toStartOf="parent"-->
                                    <!--                                        app:layout_constraintEnd_toEndOf="parent"-->
                                    <!--                                        app:layout_constraintTop_toTopOf="parent"-->
                                    <!--                                        app:layout_constraintBottom_toBottomOf="parent"-->
                                    <!--                                        android:fontFamily="@font/aregular"/>-->

                                </androidx.constraintlayout.widget.ConstraintLayout>

                                <ImageView
                                    android:id="@+id/imgFilter_right"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgFilter2_right"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:alpha=".3"
                                    android:scaleType="centerCrop" />

                                <ImageView
                                    android:id="@+id/imgResult2"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:scaleType="centerCrop" />

                                <TextView
                                    android:id="@+id/userNameRight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:fontFamily="@font/amidum"
                                    android:includeFontPadding="false"
                                    android:shadowColor="@color/black_back"
                                    android:shadowDx="2"
                                    android:layout_margin="@dimen/_5sdp"
                                    android:shadowDy="2"
                                    android:visibility="@{isHost?View.GONE:View.VISIBLE}"
                                    android:shadowRadius="2"
                                    android:text="ID: 143754"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/_12sdp" />

                                <androidx.appcompat.widget.AppCompatTextView
                                    android:id="@+id/pk_video_layout_other_host_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentStart="true"
                                    android:layout_alignParentBottom="true"
                                    android:layout_marginStart="24dp"
                                    android:layout_marginBottom="24dp"
                                    android:textColor="@android:color/white"
                                    android:textSize="14dp" />

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/pk_video_layout_enter_other_room_btn"
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_alignParentBottom="true"
                                    android:layout_marginEnd="16dp"
                                    android:layout_marginBottom="24dp"
                                    android:visibility="gone" />

                                <ImageView
                                    android:id="@+id/switchPkRoom"
                                    android:layout_width="@dimen/_60sdp"
                                    android:layout_height="@dimen/_20sdp"
                                    android:visibility="@{isHost?View.GONE:View.VISIBLE}"
                                    android:layout_alignParentBottom="true"
                                    android:layout_margin="@dimen/_3sdp"
                                    android:src="@drawable/pk_switch_btn" />

                            </RelativeLayout>


                        </androidx.cardview.widget.CardView>

                    </FrameLayout>

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/userLayBorder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="5dp"
                        android:layout_marginStart="3dp"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/shape_golden_border" />


                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="5dp"
                        android:layout_marginEnd="5dp"
                        android:layout_weight="1"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter" />


                </LinearLayout>

            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/pk_host_pk_progress_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/pk_host_video_layout_container">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="25dp"
                    android:background="@drawable/pk_progress_round_scalable_white_bg"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <LinearLayout
                        android:id="@+id/pk_progress_left_text"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/pk_left_gradient"
                        android:orientation="horizontal" />

                    <LinearLayout
                        android:id="@+id/pk_progress_right_text"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/pk_right_gradient"
                        android:orientation="horizontal" />

                </LinearLayout>

                <TextView
                    android:id="@+id/localHostRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginLeft="4dp"
                    android:layout_marginBottom="2dp"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16dp"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/remoteHostRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_gravity="center"
                    android:layout_marginRight="4dp"
                    android:layout_marginBottom="2dp"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="0"
                    android:textColor="@color/white"
                    android:textSize="16dp"
                    android:visibility="visible" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/pk_host_pk_progress_layout"
                android:layout_marginTop="@dimen/_5sdp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/uniqueIdLeft"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start|center"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="ID: 143754"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_10sdp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/uniqueIdRight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center"
                    android:fontFamily="@font/amidum"
                    android:includeFontPadding="false"
                    android:text="ID: 143754"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_10sdp" />

            </LinearLayout>


            <!-- <LinearLayout

                 android:layout_width="match_parent"
                 android:layout_height="25dp"
                 android:layout_below="@id/pk_host_video_layout_container"
                 android:orientation="horizontal">


                 <LinearLayout
                     android:id="@+id/pk_progress_left_text1"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="1"
                     android:orientation="horizontal" />

                 <ImageView
                     android:id="@+id/sparkle"
                     android:layout_width="25dp"
                     android:layout_height="25dp"
                     android:layout_gravity="center"
                     android:adjustViewBounds="true"
                     android:scaleType="fitCenter" />

                 <LinearLayout
                     android:id="@+id/pk_progress_right_text1"
                     android:layout_width="0dp"
                     android:layout_height="match_parent"
                     android:layout_weight="1"
                     android:orientation="horizontal" />


             </LinearLayout>-->
            <RelativeLayout
                android:id="@+id/imageLy"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_below="@+id/pk_host_pk_progress_layout"
                android:layout_centerHorizontal="true">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_star_pk" />

                <ImageView
                    android:id="@+id/left_host"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="15dp"
                    android:src="@drawable/girl" />

                <ImageView
                    android:id="@+id/vs"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="@dimen/_5sdp"
                    android:padding="@dimen/_5sdp"
                    android:src="@drawable/pk_vs_icon" />

                <ImageView
                    android:id="@+id/right_host"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_toEndOf="@+id/vs"
                    android:src="@drawable/girl" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <RelativeLayout
                        android:id="@+id/lyt_pk_right"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:adjustViewBounds="true"
                            android:src="@drawable/pk_side_blue" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_marginHorizontal="25dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="horizontal">


                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginHorizontal="10dp"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/hostNameRight"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/abold"
                                    android:singleLine="true"
                                    android:text="Host Name"
                                    android:textColor="@color/pink"
                                    android:textSize="16dp" />

                            </LinearLayout>

                            <com.example.rayzi.utils.UserProfileImageView
                                android:id="@+id/lytHostImageRight"
                                android:layout_width="50dp"
                                android:layout_height="50dp" />

                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:id="@+id/lyt_pk_left"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:adjustViewBounds="true"
                            android:src="@drawable/pk_side_pink" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_marginHorizontal="25dp"
                            android:layout_marginBottom="20dp"
                            android:orientation="horizontal">

                            <com.example.rayzi.utils.UserProfileImageView
                                android:id="@+id/lytHostImageLeft"
                                android:layout_width="50dp"
                                android:layout_height="50dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginHorizontal="10dp"
                                android:orientation="vertical">


                                <TextView
                                    android:id="@+id/hostNameLeft"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/abold"
                                    android:singleLine="true"
                                    android:text="Host Name"
                                    android:textColor="#1046B5"
                                    android:textSize="16dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/pkAnim"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_centerInParent="true"
                android:visibility="visible"
                app:lottie_loop="true"
                app:lottie_rawRes="@raw/pk_cresh" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/pk_host_remaining_time_layout"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:layout_below="@id/titleLayout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="5dp"
            android:background="@drawable/pk_timer_bg"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/_10sdp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:src="@drawable/icon_pk_countdown" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/pk_host_remaining_time_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/_5sdp"
                android:gravity="center_vertical"
                android:text="--:--:--"
                android:textAlignment="gravity"
                android:textColor="@color/white"
                android:textSize="12dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/abold"
            android:text="3"
            android:textColor="@color/blackpure"
            android:textSize="50dp"
            android:visibility="gone" />


        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/mainLay"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="40dp">

            <ImageView
                android:id="@+id/startPK"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_centerInParent="true"
                android:layout_marginEnd="50dp"
                android:src="@drawable/start_pk"
                android:visibility="gone" />

        </RelativeLayout>

    </RelativeLayout>


</layout>